# ============================================================
#  IPL Friends Tracker — Environment Variables
#  Copy this file to .env and fill in your values
# ============================================================

# Server port (leave as 3000, Render/Railway will override automatically)
PORT=3000

# ── WhatsApp Recipients ──────────────────────────────────────
# Format: countrycode+phonenumber:callmebot_api_key
# Add one person per entry, comma separated
# Each person must activate CallMeBot first (see SETUP.md)
#
# Example:
# WHATSAPP_RECIPIENTS=919876543210:abc123,919876543211:def456
#
WHATSAPP_RECIPIENTS=

# ── Optional: CricAPI key for more reliable data ─────────────
# Free tier: 100 requests/day at https://cricapi.com
# Leave blank to use the free Cricbuzz scraper
CRICAPI_KEY=
